<?xml version="1.0" encoding="utf-8"?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
	  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

	<targets>

		<target xsi:type="File"
				name="file"
				fileName="C:/Yash Patel/Apis/EmployeeAPI/EmployeeAPI/logs/${shortdate}.txt"
				layout="----------------------------------------------------------------------------------------------------------------------------------------${newline}|${time}|${level:uppercase=true}|${logger}|${message}|${exception:format=tostring}" />

		<target xsi:type="Console"
				name="console"
				layout="----------------------------------------------------------------------------------------------------------------------------------------${newline}|${time}|${level:uppercase=true}|${logger}|${message}|${exception:format=tostring}" />
	</targets>

	<rules>

		<!-- Microsoft logs ignore -->
		<logger name="Microsoft.*" final="true" />

		<!-- System logs ignore -->
		<logger name="System.*" final="true" />

		<!-- Application logs -->
		<logger name="*" minlevel="Debug" writeTo="file,console" />
	</rules>

</nlog>